# =============================================================================
# RPG Workspace Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Sections are ordered by crate: rpg-mcp, rpg-encoder (llm), rpg-generator.

# =============================================================================
# RPG-MCP SERVER CONFIGURATION
# =============================================================================
# Required for running the MCP server (rpg-mcp binary or Docker container).

# Path to the workspace root to analyze (required)
RPG_WORKSPACE=/path/to/your/project/src

# Directory for persisted graph data (optional, defaults to <workspace>/.rpg-data)
RPG_DATA_DIR=/path/to/output/data

# Hash mode for detecting file changes: "mtime" (default) or "content"
RPG_HASH_MODE=mtime

# Enable LLM semantic enrichment during initial encode (optional, default off)
# Set to "true" or "1" to enable. Requires OPENAI_API_KEY below.
RPG_SEMANTIC=false

# Explicit path to .env file (optional)
# If unset, rpg-mcp searches: CARGO_MANIFEST_DIR/../.env, RPG_WORKSPACE/../.env, ./.env
# RPG_ENV_FILE=/path/to/custom/.env

# Log level for tracing (optional, defaults to "info")
# Uses standard RUST_LOG filter syntax: "rpg_mcp=debug", "info", "rpg_mcp=trace"
# RUST_LOG=info

# =============================================================================
# LLM CONFIGURATION — rpg-encoder (feature: llm)
# =============================================================================
# Required when RPG_SEMANTIC=true or using LLM-based feature extraction.

# OpenAI-compatible API key (required for LLM features)
OPENAI_API_KEY=your_api_key_here

# API base URL (optional, defaults to https://api.openai.com/v1)
# For Z.ai:   https://api.z.ai/api/coding/paas/v4
# For Azure:  https://your-resource.openai.azure.com
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name (optional, defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Max concurrent LLM requests (optional, defaults to 3)
OPENAI_MAX_CONCURRENT=3

# Enable reasoning/thinking mode (optional, default off)
# Set to "true" or "1" for models that support reasoning (e.g. OpenAI o-series)
OPENAI_REASONING=false

# Debug mode for LLM client — logs full request/response bodies to stderr
RPG_DEBUG=false

# Debug output file (optional, writes LLM request/response JSON to file)
# RPG_DEBUG_FILE=/tmp/rpg-llm-debug.json

# =============================================================================
# LLM CONFIGURATION — rpg-generator
# =============================================================================
# Used by the code generator crate. Shares OPENAI_API_KEY, OPENAI_BASE_URL,
# OPENAI_MODEL, and OPENAI_REASONING with the encoder (same env vars).

# =============================================================================
# YAML CONFIGURATION ALTERNATIVE (rpg-encoder semantic features)
# =============================================================================
# Some rpg-encoder features support YAML configuration files:
#   Global:  ~/.rpg/embedding.yaml
#   Project: ./.rpg/embedding.yaml
# Project settings override global settings.
# Variables documented in the old embedding section below may be configured
# there instead of via environment variables.

# =============================================================================
# EMBEDDING CONFIGURATION (legacy / yaml-based)
# =============================================================================
# These variables may be used by embedding-related features. Check the
# embedding YAML config path above for the canonical configuration method.

# RPGEN_EMBEDDING_ENDPOINT=http://localhost:8080/v1
# RPGEN_EMBEDDING_MODEL=qwen3-embedding
# RPGEN_EMBEDDING_DIMENSION=4096
