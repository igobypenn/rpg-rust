# =============================================================================
# RPG Encoder Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Only set the variables you need based on which features you're using.

# =============================================================================
# SEMANTIC EMBEDDING CONFIGURATION (semantic feature)
# =============================================================================
# Required for: semantic feature, embedding-based analysis

# Embedding API endpoint (required for semantic features)
# For llama.cpp with OpenAI-compatible API:
#   RPGEN_EMBEDDING_ENDPOINT=http://localhost:8080/v1
# For Ollama:
#   RPGEN_EMBEDDING_ENDPOINT=http://localhost:11434/v1
# For OpenAI:
#   RPGEN_EMBEDDING_ENDPOINT=https://api.openai.com/v1
RPGEN_EMBEDDING_ENDPOINT=http://localhost:8080/v1

# Embedding model name (optional, defaults to qwen3-embedding)
# Examples: qwen3-embedding, nomic-embed-text, text-embedding-3-small
RPGEN_EMBEDDING_MODEL=qwen3-embedding

# Embedding dimension (optional, defaults to 1024)
# Set this if your model has a different dimension:
# - Qwen3-Embedding-8B: 4096
# - nomic-embed-text: 768
# - text-embedding-3-small: 1536
# RPGEN_EMBEDDING_DIMENSION=4096

# =============================================================================
# LLM CONFIGURATION (llm feature)
# =============================================================================
# Required for: llm feature, LLM-based feature extraction

# OpenAI/Z.ai API key (required for LLM features)
OPENAI_API_KEY=your_api_key_here

# API base URL (optional, defaults to OpenAI's API)
# For Z.ai:
#   OPENAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
# For Azure OpenAI:
#   OPENAI_BASE_URL=https://your-resource.openai.azure.com
OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use for LLM operations (optional, defaults to gpt-4o-mini)
# Examples: gpt-4o, gpt-4o-mini, glm-4.7-flashx
OPENAI_MODEL=gpt-4o-mini

# Maximum concurrent LLM requests (optional, defaults to 3)
# Lower this if you hit rate limits
OPENAI_MAX_CONCURRENT=3

# =============================================================================
# FEATURE-SPECIFIC NOTES
# =============================================================================
#
# For SEMANTIC features only (no LLM):
#   - Set: RPGEN_EMBEDDING_ENDPOINT
#   - Optional: RPGEN_EMBEDDING_MODEL
#   - Leave LLM vars unset
#
# For LLM-based feature extraction:
#   - Set: OPENAI_API_KEY
#   - Optional: OPENAI_BASE_URL, OPENAI_MODEL, OPENAI_MAX_CONCURRENT
#
# For both features:
#   - Set all relevant variables above
#
# =============================================================================
# CONFIGURATION FILE ALTERNATIVE
# =============================================================================
# You can also use YAML configuration files instead of environment variables:
#   Global:  ~/.rpg/embedding.yaml
#   Project: ./.rpg/embedding.yaml
# Project settings override global settings.
# See: rpg-encoder/docs/configuration.md
